# =============================================================================
# .env.example — Environment Variables (Gemini 2.5 Flash edition)
# =============================================================================
# CHANGED: ANTHROPIC_API_KEY removed → GEMINI_API_KEY added
#
# HOW TO GET GEMINI_API_KEY (free):
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API Key"
# 3. Select a Google Cloud project (or create one)
# 4. Copy the key (starts with "AIza...")
#
# FREE TIER LIMITS (Google AI Studio):
#   gemini-2.5-flash: 1500 requests/day, 1M tokens/min
#   More than enough for this project.
# =============================================================================

# -----------------------------------------------
# Gemini API (Required — replaces ANTHROPIC_API_KEY)
# -----------------------------------------------
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# -----------------------------------------------
# Google Calendar OAuth (Required — UNCHANGED)
# -----------------------------------------------
# 1. Go to https://console.cloud.google.com/
# 2. Enable "Google Calendar API"
# 3. Create OAuth 2.0 Client ID (Desktop app)
# 4. Download JSON → rename to credentials.json → put in backend/
# 5. First run opens browser for Google login → creates token.json
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# -----------------------------------------------
# Agent Configuration (UNCHANGED)
# -----------------------------------------------
FETCH_DAYS_AHEAD=7
REFRESH_INTERVAL_MINUTES=30
BRIEFS_FILE_PATH=briefs_cache.json

# -----------------------------------------------
# API Configuration (UNCHANGED)
# -----------------------------------------------
PORT=8000
ENV=development

# -----------------------------------------------
# Streamlit (UNCHANGED)
# -----------------------------------------------
API_URL=http://localhost:8000
